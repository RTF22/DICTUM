ANTHROPIC_API_KEY=sk-ant-your-key-here

# Language — controls UI, Claude prompts and Whisper STT.
# Allowed values: de, en. Default: de. Can be toggled at runtime in the tray menu.
# The tray selection (stored in state.json) overrides this value.
# VOCIX_LANGUAGE=de

# Override for Whisper STT language (rarely needed — follows VOCIX_LANGUAGE by default).
# VOCIX_WHISPER_LANGUAGE=

# Whisper model — tiny | base | small (default) | medium | large-v3 | large-v3-turbo
# Larger models are more accurate but slower. The tray menu selection (state.json)
# overrides this value.
# VOCIX_WHISPER_MODEL=small

# Acceleration — auto (GPU if available) | gpu (force CUDA) | cpu (force CPU)
# GPU mode requires `pip install -r requirements-gpu.txt` (only available on
# source installs; the packaged ZIP is CPU-only). Default: auto.
# VOCIX_WHISPER_ACCELERATION=auto

# Hotkeys — Push-to-Talk (hold = record, release = process)
# Default: pause (no standard Windows / browser / Office / IDE binding — safe everywhere).
# Laptop without a dedicated Pause key? Try `scroll lock` or `f7` instead.
#
# Single keys:    pause, scroll lock, f7, f8, f6, f5, print screen
# Combinations:   ctrl+shift+space, alt+shift+r, ctrl+alt+d
#
# VOCIX_HOTKEY_RECORD=pause
# VOCIX_HOTKEY_MODE_A=ctrl+shift+1
# VOCIX_HOTKEY_MODE_B=ctrl+shift+2
# VOCIX_HOTKEY_MODE_C=ctrl+shift+3

# Logging (DEBUG, INFO, WARNING, ERROR)
# VOCIX_LOG_LEVEL=INFO
# VOCIX_LOG_FILE=vocix.log

# RDP mode: longer clipboard delays for Remote Desktop sessions
# VOCIX_RDP_MODE=true

# --- LLM-Provider (optional) ----------------------------------------------
# Wahl pro Modus. Werte: anthropic | openai | ollama
# VOCIX_LLM_DEFAULT=anthropic
# VOCIX_LLM_BUSINESS=ollama
# VOCIX_LLM_RAGE=anthropic

# OpenAI-kompatible Provider (OpenAI, Groq, OpenRouter, LM Studio, …)
# VOCIX_LLM_OPENAI_API_KEY=sk-…
# VOCIX_LLM_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# VOCIX_LLM_OPENAI_MODEL=llama-3.1-70b-versatile
# VOCIX_LLM_OPENAI_TIMEOUT=15

# Ollama (lokal)
# VOCIX_LLM_OLLAMA_BASE_URL=http://localhost:11434
# VOCIX_LLM_OLLAMA_MODEL=llama3.1:8b
# VOCIX_LLM_OLLAMA_TIMEOUT=30

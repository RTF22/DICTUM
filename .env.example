ANTHROPIC_API_KEY=sk-ant-your-key-here

# Sprache / Language — steuert UI, Claude-Prompts und Whisper-STT.
# Erlaubte Werte: de, en. Default: de. Kann zur Laufzeit im Tray umgeschaltet werden.
# Die Tray-Auswahl (in state.json) hat Vorrang vor diesem Wert.
# Controls UI, Claude prompts and Whisper STT. Values: de, en. Default: de.
# The tray selection (stored in state.json) overrides this value.
# VOCIX_LANGUAGE=de

# Override für Whisper-STT-Sprache (selten nötig — normalerweise folgt sie VOCIX_LANGUAGE).
# Override for Whisper STT language (rarely needed — follows VOCIX_LANGUAGE by default).
# VOCIX_WHISPER_LANGUAGE=

# Hotkeys — Push-to-Talk (halten = aufnehmen, loslassen = verarbeiten)
# Standard: F9
#
# Einzeltasten:       f9, f8, f7, f6, f5, pause, scroll lock, print screen
# Kombinationen:      ctrl+shift+space, alt+shift+r, ctrl+alt+d
#
# VOCIX_HOTKEY_RECORD=f9
# VOCIX_HOTKEY_MODE_A=ctrl+shift+1
# VOCIX_HOTKEY_MODE_B=ctrl+shift+2
# VOCIX_HOTKEY_MODE_C=ctrl+shift+3

# Logging (DEBUG, INFO, WARNING, ERROR)
# VOCIX_LOG_LEVEL=INFO
# VOCIX_LOG_FILE=vocix.log

# RDP-Modus: Längere Clipboard-Delays für Remote-Desktop-Sessions
# VOCIX_RDP_MODE=true
